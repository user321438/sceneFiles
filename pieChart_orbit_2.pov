#declare _T_rise        = 0.162500;
#declare _c1            = min(clock, _T_zoom) / _T_zoom;
#declare _c2            = max(min(clock, _T_rise) - _T_zoom, 0.0) / (_T_rise - _T_zoom);
#declare _c3            = max(clock - _T_rise, 0.0) / (1.0 - _T_rise);
// Phase 1: cubic ease-out zoom (fast approach, decelerates to close position)
#declare _t1            = _c1 * (3.0 - _c1 * (3.0 - _c1));
#declare _p1_r          = _orb_r_far + (_orb_r_close - _orb_r_far) * _t1;
#declare _p1_h          = _orb_h - (_orb_h - _orb_ty) * _t1;
#declare _p1_x          = _orb_tx + _p1_r * sin(_orb_a0);
#declare _p1_y          = _p1_h;
#declare _p1_z          = _orb_tz + _p1_r * cos(_orb_a0);
// Phase 2: smoothstep orbit + rise
#declare _ss2           = _c2 * _c2 * (3.0 - 2.0 * _c2);
#declare _p2_a          = _orb_a0 + _ss2 * _orb_da;
#declare _p2_h          = _orb_ty + _ss2 * _orb_vs;
#declare _p2_x          = _orb_tx + _orb_r_close * sin(_p2_a);
#declare _p2_y          = _p2_h;
#declare _p2_z          = _orb_tz + _orb_r_close * cos(_p2_a);
// Phase 3: radial breathing (subtle dolly out-and-back) + very slow rotation
#declare _float_a       = _orb_a_end + _orb_float_sda * _c3;
#declare _float_r       = _orb_r_close + _orb_float_amp * sin(2*pi * 10.000000 * _c3);
#declare _p3_x          = _orb_tx + _float_r * sin(_float_a);
#declare _p3_y          = _orb_h_end;
#declare _p3_z          = _orb_tz + _float_r * cos(_float_a);
#declare _cam_x         = select(clock - _T_zoom, _p1_x, select(clock - _T_rise, _p2_x, _p3_x));
#declare _cam_y         = select(clock - _T_zoom, _p1_y, select(clock - _T_rise, _p2_y, _p3_y));
#declare _cam_z         = select(clock - _T_zoom, _p1_z, select(clock - _T_rise, _p2_z, _p3_z));
camera {
  perspective
  location <_cam_x, _cam_y, _cam_z>
  look_at  <_orb_tx, _orb_ty, _orb_tz>
  right x*image_width/image_height
  angle 42.0000

}
